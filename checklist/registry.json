{
  "version": "1.0",
  "description": "Canonical VAPT checklist registry. Every test the platform can run is defined here. canonical_name is law — it appears verbatim in reports.",
  "items": [

    {
      "id": "WEB-001",
      "canonical_name": "Reflected Cross-Site Scripting (XSS)",
      "category": "injection",
      "domain": "web",
      "source": "internal",
      "owasp_ref": "A03:2021",
      "cwe": "CWE-79",
      "severity_default": "Medium",
      "agent": "web_agent",
      "tools": ["zap", "nuclei"],
      "aliases": ["reflected xss", "xss reflected", "rxss"],
      "preconditions": ["input_fields_present", "no_strict_output_encoding"],
      "test_strategy": {
        "recon_required": true,
        "auth_required": false,
        "input_discovery": true
      },
      "test_steps": [
        "Identify all input parameters (GET, POST, headers, cookies)",
        "Inject standard XSS payloads: <script>alert(1)</script>",
        "Check if payload is reflected in response without encoding",
        "Test in different contexts: HTML body, attribute, JS, URL"
      ],
      "expected_evidence": ["payload_reflected", "unsanitized_output", "alert_executed"],
      "evidence_requirements": {
        "request": true, "response": true, "payload": true, "screenshot": false
      },
      "remediation_ref": "https://cheatsheetseries.owasp.org/cheatsheets/Cross_Site_Scripting_Prevention_Cheat_Sheet.html"
    },

    {
      "id": "WEB-002",
      "canonical_name": "Stored Cross-Site Scripting (XSS)",
      "category": "injection",
      "domain": "web",
      "source": "internal",
      "owasp_ref": "A03:2021",
      "cwe": "CWE-79",
      "severity_default": "High",
      "agent": "web_agent",
      "tools": ["zap", "nuclei"],
      "aliases": ["stored xss", "persistent xss"],
      "preconditions": ["input_fields_present", "data_persistence"],
      "test_strategy": {
        "recon_required": true,
        "auth_required": false,
        "input_discovery": true
      },
      "test_steps": [
        "Find fields that store and re-display user input (comments, profiles, etc.)",
        "Inject XSS payload into stored field",
        "Navigate to the page that renders stored data",
        "Verify payload executes on render"
      ],
      "expected_evidence": ["payload_stored", "payload_executed_on_render"],
      "evidence_requirements": {
        "request": true, "response": true, "payload": true, "screenshot": false
      },
      "remediation_ref": "https://cheatsheetseries.owasp.org/cheatsheets/Cross_Site_Scripting_Prevention_Cheat_Sheet.html"
    },

    {
      "id": "WEB-003",
      "canonical_name": "SQL Injection",
      "category": "injection",
      "domain": "web",
      "source": "internal",
      "owasp_ref": "A03:2021",
      "cwe": "CWE-89",
      "severity_default": "Critical",
      "agent": "web_agent",
      "tools": ["sqlmap", "zap"],
      "aliases": ["sqli", "sql injection", "blind sqli", "error-based sqli"],
      "preconditions": ["database_backend", "user_input_to_query"],
      "test_strategy": {
        "recon_required": true,
        "auth_required": false,
        "input_discovery": true
      },
      "test_steps": [
        "Identify parameters sent to backend queries",
        "Test with ' and \" to trigger SQL errors",
        "Use boolean-based payloads: ' AND 1=1-- vs ' AND 1=2--",
        "Test time-based blind: ' AND SLEEP(5)--",
        "Use sqlmap for automated extraction if manual confirms"
      ],
      "expected_evidence": ["sql_error_message", "boolean_difference", "time_delay", "data_extracted"],
      "evidence_requirements": {
        "request": true, "response": true, "payload": true, "screenshot": false
      },
      "remediation_ref": "https://cheatsheetseries.owasp.org/cheatsheets/SQL_Injection_Prevention_Cheat_Sheet.html"
    },

    {
      "id": "WEB-004",
      "canonical_name": "Cross-Site Request Forgery (CSRF)",
      "category": "session",
      "domain": "web",
      "source": "internal",
      "owasp_ref": "A01:2021",
      "cwe": "CWE-352",
      "severity_default": "Medium",
      "agent": "web_agent",
      "tools": ["zap", "manual"],
      "aliases": ["csrf", "xsrf"],
      "preconditions": ["authenticated_session", "state_changing_requests"],
      "test_strategy": {
        "recon_required": true,
        "auth_required": true,
        "input_discovery": false
      },
      "test_steps": [
        "Identify state-changing requests (POST, PUT, DELETE)",
        "Check for CSRF token in request",
        "Craft HTML form that submits request cross-origin",
        "Verify if request succeeds without valid CSRF token"
      ],
      "expected_evidence": ["missing_csrf_token", "cross_origin_request_accepted"],
      "evidence_requirements": {
        "request": true, "response": true, "payload": true, "screenshot": false
      },
      "remediation_ref": "https://cheatsheetseries.owasp.org/cheatsheets/Cross-Site_Request_Forgery_Prevention_Cheat_Sheet.html"
    },

    {
      "id": "WEB-005",
      "canonical_name": "Insecure Direct Object Reference (IDOR)",
      "category": "access_control",
      "domain": "web",
      "source": "internal",
      "owasp_ref": "A01:2021",
      "cwe": "CWE-284",
      "severity_default": "High",
      "agent": "web_agent",
      "tools": ["burp", "manual"],
      "aliases": ["idor", "broken object level authorization", "bola"],
      "preconditions": ["authenticated_session", "object_ids_in_requests"],
      "test_strategy": {
        "recon_required": true,
        "auth_required": true,
        "input_discovery": true
      },
      "test_steps": [
        "Identify endpoints that take object IDs (user_id, order_id, file_id)",
        "Authenticate as User A, note object IDs",
        "Authenticate as User B, attempt to access User A objects",
        "Verify if authorization is enforced at object level"
      ],
      "expected_evidence": ["unauthorized_object_access", "cross_user_data_visible"],
      "evidence_requirements": {
        "request": true, "response": true, "payload": false, "screenshot": false
      },
      "remediation_ref": "https://cheatsheetseries.owasp.org/cheatsheets/Insecure_Direct_Object_Reference_Prevention_Cheat_Sheet.html"
    },

